# Copy to .env and fill in. .env is gitignored.

# Environment: dev | staging | prod
ENV=dev
# DEBUG defaults to true when ENV=dev; set explicitly to override.
# DEBUG=true

PROJECT_NAME=Template Backend

# CORS: comma-separated origins, or leave empty to allow all ("*").
CORS_ORIGINS_STR=

# ---- Database (PostgreSQL) -------------------------------------------------
# Either set a full DATABASE_URL (async driver) ...
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/app
# ... or set the discrete DB_* parts below (used when DATABASE_URL is unset).
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
# DB_SSL: disable | require (anything non-"disable" enables TLS)
DB_SSL=disable

# ---- Auth (JWT) -----------------------------------------------------------
# MUST be overridden in production. Use a long random string (>= 32 chars).
JWT_SECRET_KEY=change-me-in-prod-change-me-in-prod-32chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- LiveKit (room token minting) -----------------------------------------
# Required for POST /api/v1/token. Use the SAME key/secret your agent worker
# uses, or the minted token will not be valid for the room the agent joins.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- VoiceGateway telemetry (backend AI cost) -----------------------------
# When set, the backend pushes the hidden Cognee + onboarding LLM/embedding
# spend to the collector, attributed per realtor (tenant) under the same
# realty-recall project as the voice agent. Unset -> a clean no-op. Use the
# same collector URL as the agent; the vk_ key binds rows to the cloud tenant.
# VOICEGW_COLLECTOR_URL=https://cloud-api-production-dc6e.up.railway.app
# VOICEGW_API_KEY=vk_your_ingest_key

# ---- Optional ops ---------------------------------------------------------
# SENTRY_DSN=
# API_ROOT_PATH=/
