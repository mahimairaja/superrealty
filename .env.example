# Root env for the RealtyRecall docker compose stack

# ===== LiveKit (shared by backend + agent; the browser also connects here) =====
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ===== Agent: voice providers =====
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
AGENT_NAME=realty
AGENT_MAX_CALL_SECONDS=600
BACKEND_URL=http://backend:8080

# ===== Cognee memory (system of record for listings + buyers) =====
# Cognee uses OpenAI (OPENAI_API_KEY above) for extraction + embeddings.
# Graph backend = Neo4j Community (the 'neo4j' service). Vector + relational = pgvector Postgres.
# APOC must be enabled on the Neo4j service or `onboard/confirm` 500s: docker-compose sets
# NEO4J_PLUGINS='["apoc"]' + NEO4J_dbms_security_procedures_unrestricted=apoc.* for local dev.
# For a self-hosted prod Neo4j, set the same two vars on that service (Aura ships APOC Core).
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://neo4j:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=neo4jpassword
NEO4J_PASSWORD=neo4jpassword
VECTOR_DB_PROVIDER=pgvector
# Cognee relational store (reuses the pgvector Postgres 'db' service).
COGNEE_DB_PROVIDER=postgres

# ===== cal.com booking (new RealtyRecall calendar event) =====
CAL_API_KEY=
RR_CAL_EVENT_TYPE_ID=
CAL_DEFAULT_TIMEZONE=America/Toronto

# ===== Telnyx (post-call lead handoff SMS to the realtor) =====
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
# The realtor's phone for the post-call lead handoff SMS.
REALTOR_SMS_TO=

# ===== Backend =====
ENV=dev
JWT_SECRET_KEY=change-me-in-prod-change-me-in-prod-32chars-min
CORS_ORIGINS_STR=http://localhost:5173
WIDGET_ALLOWED_ORIGINS_STR=
WIDGET_TOKEN_RATELIMIT_PER_MIN=20
WIDGET_TOKEN_TTL_SECONDS=300
# Postgres (the compose 'db' service): operational Booking + CallLog, and Cognee relational/vector.
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=app
DB_SSL=disable
# PostHog conversion analytics (optional; no-op when unset).
POSTHOG_API_KEY=

# ===== Frontend (baked into the static build) =====
VITE_TOKEN_ENDPOINT=http://localhost:8000/api/v1/token
VITE_AGENT_NAME=realty

# ===== Optional =====
# SENTRY_DSN=
COGNEE_DB_NAME=cognee_db
