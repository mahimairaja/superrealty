# Frontend (Vite) build-time env. Vite bakes VITE_* at build, so set these in the
# Vercel project (Production + Preview) before deploying. Locally, copy to .env.

# Backend token endpoint (the rest of the API base is derived by stripping /token).
VITE_TOKEN_ENDPOINT=http://localhost:8000/api/v1/token

# Must match the agent worker's agent_name (AGENT_NAME in the agent package).
VITE_AGENT_NAME=realty

# Clerk auth (multi-tenant console). Publishable key from your Clerk app.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# VoiceGateway usage widget iframe base (per-realtor usage on the Overview).
VITE_VG_WIDGET_URL=https://dash.voicegateway.dev/embed/usage
